# Yönetim paneli ve yazı API'si için HTTP Basic Auth bilgileri
# Bu değişkenler .env.local dosyasında tanımlanmalıdır
ADMIN_USER=kullanici_adi
ADMIN_PASSWORD=güvenli_sifre

# Üye oturum çerezlerini şifrelemek için: en az 32 karakter rastgele bir değer
SESSION_SECRET=degistir_en_az_32_karakter_olan_gizli_bir_deger

# (Opsiyonel) Vercel KV / Upstash Redis yapılandırması
# Tanımlı değilse kullanıcılar data/users.json dosyasına yazılır.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
